# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# --- Local voice assistant ---
# Anthropic API key for intent classification (https://console.claude.com/)
ANTHROPIC_API_KEY=

# Porcupine wake-word access key (free: https://console.picovoice.ai/)
PORCUPINE_ACCESS_KEY=

# Optional overrides
# HEY_CINDY_MODEL=claude-sonnet-4-6      # or claude-haiku-4-5 (cheaper/faster)
# HEY_CINDY_LLM_TIMEOUT=5                # seconds before falling back to keywords
# HEY_CINDY_KEYWORD_PATH=Hey-Cindy_en_mac_v4_0_0/Hey-Cindy_en_mac_v4_0_0.ppn

# --- Cloud API: client connection ---
HEY_CINDY_CLOUD=http://3.234.157.34:8000
HEY_CINDY_TOKEN=cindy-dev-token-123

# --- Cloud API: server-side datastores (only needed when running cloud/app.py) ---
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql+psycopg2://cindy:cindy@localhost:5432/hey_cindy
